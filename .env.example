# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/aphina

# Telegram
BOT_TOKEN=your_telegram_bot_token_here
BOT_PASSWORD=your_secret_password_here

# OpenRouter — все AI запросы идут через него
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Models (all via OpenRouter)
VISION_MODEL=openai/gpt-4o
TEXT_MODEL=openai/gpt-4o
IMAGE_MODEL=openai/dall-e-3
TRANSCRIPTION_MODEL=google/gemini-2.0-flash-001

# App
APP_NAME=Aphina Calorie Tracker
APP_URL=http://localhost:8000
